# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# BigRed200 vLLM endpoint
BIGRED200_VLLM_URL=http://bigred200-node:8000/v1
BIGRED200_EMBED_MODEL=BAAI/bge-m3
BIGRED200_USERNAME=your_username
BIGRED200_SSH_HOST=bigred200.indiana.edu

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documind_chunks
QDRANT_API_KEY=

# PostgreSQL
DATABASE_URL=postgresql://documind:documind_secret@localhost:5432/documind
DATABASE_URL_ASYNC=postgresql+asyncpg://documind:documind_secret@localhost:5432/documind

# Redis
REDIS_URL=redis://localhost:6379

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_me_in_production

# Embedding mode: "local" | "bigred200"
EMBEDDING_MODE=local
LOCAL_EMBED_MODEL=BAAI/bge-small-en-v1.5
